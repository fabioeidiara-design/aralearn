{
  "name": "aralearn",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "scripts": {
    "build:hardcoded-content": "node scripts/sync-hardcoded-content.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:browsers": "playwright install chromium",
    "validate:web": "npm run test:unit && npm run test:e2e",
    "validate": "pwsh -NoProfile -File ./scripts/validate.ps1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "fflate": "^0.8.2"
  },
  "dependencies": {
    "elkjs": "^0.11.1"
  }
}
